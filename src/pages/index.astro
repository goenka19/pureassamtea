---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { BRANDS } from '../data/brands';
---

<Layout title="Pureassamtea — Premium B2B Tea Manufacturing" description="B2B tea manufacturer from Upper Assam, India. CTC tea supply, wholesale, and private labeling since 1954.">
  <Header />

  <main>

    <!-- ================================================================
         HERO — split: text left, image right
    ================================================================ -->
    <section class="relative overflow-hidden bg-white" style="background-image: radial-gradient(circle at 1px 1px, rgba(14,14,14,0.04) 1px, transparent 0); background-size: 22px 22px;">
      <!-- Green circle decorative blob -->
      <div class="absolute top-[-160px] right-[-160px] w-[480px] h-[480px] rounded-full bg-tea-light opacity-40 pointer-events-none" aria-hidden="true"></div>

      <div class="relative z-10 max-w-[1200px] mx-auto px-8 mob:px-4 py-16 pat:py-10">
        <div class="grid grid-cols-[1.05fr_1fr] gap-[72px] items-center pat:grid-cols-1 pat:gap-12">

          <!-- LEFT: Text -->
          <div>
            <p class="text-[12px] font-semibold tracking-[0.1em] uppercase text-tea-green mb-3">Established 1997 · Dibrugarh, Assam</p>
            <h1 class="text-[clamp(40px,4.5vw,60px)] font-bold tracking-tight leading-[1.1] text-ink mt-3 mb-5">
              Tea from the gardens of Upper Assam, four generations on.
            </h1>
            <p class="text-[18px] leading-[1.7] text-ink-2 max-w-[520px] pat:max-w-none mb-8">
              Family-owned, family-run. Eight wholesale brands of CTC and Orthodox tea, produced across sixteen factories and gardens. Trusted by brokers and buyers across India and beyond.
            </p>
            <div class="flex flex-wrap gap-3 mb-12">
              <a href="/brands" class="inline-flex items-center gap-2 bg-tea-green text-white text-[14px] font-medium px-7 py-[14px] rounded-lg hover:bg-[#005530] transition-colors duration-150 no-underline">
                Explore Our Brands
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="/contact" class="inline-flex items-center gap-2 bg-transparent text-ink text-[14px] font-medium px-7 py-[14px] rounded-lg border border-line hover:border-ink transition-colors duration-150 no-underline">
                Request Samples
              </a>
            </div>
            <!-- Stats row — desktop only; mobile version is below the image -->
            <div class="grid grid-cols-3 gap-12 pt-8 border-t border-line max-w-[520px] pat:hidden">
              <div>
                <strong class="block text-[34px] font-bold tracking-tight text-tea-green leading-none">2.7M</strong>
                <span class="block text-[13px] text-ink-3 mt-2 leading-snug">Annual CTC output</span>
              </div>
              <div>
                <strong class="block text-[34px] font-bold tracking-tight text-tea-green leading-none">16</strong>
                <span class="block text-[13px] text-ink-3 mt-2 leading-snug">Factories &amp; gardens</span>
              </div>
              <div>
                <strong class="block text-[34px] font-bold tracking-tight text-tea-green leading-none">20+</strong>
                <span class="block text-[13px] text-ink-3 mt-2 leading-snug">Export markets</span>
              </div>
            </div>
          </div>

          <!-- RIGHT: Image + badge -->
          <div class="relative aspect-[4/5] max-h-[560px] pat:aspect-[4/3] pat:max-h-none">
            <div class="w-full h-full rounded-2xl overflow-hidden shadow-[0_24px_64px_rgba(14,14,14,0.12)]">
              <img
                src="/images/tea-garden-hero.jpg"
                alt="Assam tea garden"
                class="w-full h-full object-cover"
                width="600"
                height="750"
              />
            </div>
            <!-- Floating badge -->
            <div class="absolute left-[-28px] bottom-8 bg-white rounded-xl px-6 py-5 shadow-[0_8px_24px_rgba(14,14,14,0.10)] border border-[#F0F0EE] min-w-[200px]
                        pat:left-4 pat:bottom-4 pat:px-4 pat:py-4 pat:min-w-0">
              <div class="flex items-start text-[48px] font-bold text-tea-green tracking-tight leading-none pat:text-[36px]">
                70<span class="text-[24px] mt-1.5 pat:text-[18px]">+</span>
              </div>
              <div class="text-[12px] text-ink-2 leading-snug mt-1.5 uppercase font-medium tracking-wide">Years of family tea craft</div>
            </div>
          </div>

        </div>
      </div>

      <!-- Stats row — mobile only, below the image -->
      <div class="hidden pat:grid grid-cols-3 gap-6 px-8 mob:px-4 pt-8 pb-2 border-t border-line mx-auto max-w-[1200px]">
        <div>
          <strong class="block text-[28px] font-bold tracking-tight text-tea-green leading-none">2.7M</strong>
          <span class="block text-[12px] text-ink-3 mt-1.5 leading-snug">Annual CTC output</span>
        </div>
        <div>
          <strong class="block text-[28px] font-bold tracking-tight text-tea-green leading-none">16</strong>
          <span class="block text-[12px] text-ink-3 mt-1.5 leading-snug">Factories &amp; gardens</span>
        </div>
        <div>
          <strong class="block text-[28px] font-bold tracking-tight text-tea-green leading-none">20+</strong>
          <span class="block text-[12px] text-ink-3 mt-1.5 leading-snug">Export markets</span>
        </div>
      </div>
    </section>


    <!-- ================================================================
         TRUST STRIP — proof-of-process signals
    ================================================================ -->
    <div class="bg-white border-y border-[#F0F0EE]">
      <div class="max-w-[1200px] mx-auto px-8 mob:px-0 py-4">

        <!-- Desktop: static row -->
        <ul class="mob:hidden list-none m-0 p-0 flex justify-center items-center gap-x-7">
          {[
            'CTC &amp; Orthodox teas',
            '25 kg PP bags standard',
            'Samples on request',
            '2-day response',
            '20+ markets supplied',
          ].map((item, i) => (
            <li class="flex items-center gap-2 shrink-0">
              {i > 0 && <span class="text-[#D0D0D0] mr-5" aria-hidden="true">·</span>}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-tea-green shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-[13px] font-medium text-ink-2" set:html={item}></span>
            </li>
          ))}
        </ul>

        <!-- Mobile: marquee ticker -->
        <div class="hidden mob:block overflow-hidden">
          <ul class="ticker list-none m-0 p-0 flex items-center gap-x-8 whitespace-nowrap w-max">
            {[
              'CTC &amp; Orthodox teas',
              '25 kg PP bags standard',
              'Samples on request',
              '2-day response',
              '20+ markets supplied',
              'CTC &amp; Orthodox teas',
              '25 kg PP bags standard',
              'Samples on request',
              '2-day response',
              '20+ markets supplied',
            ].map((item) => (
              <li class="flex items-center gap-2 shrink-0">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-tea-green shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="text-[13px] font-medium text-ink-2" set:html={item}></span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>


    <!-- ================================================================
         ABOUT BAND — cream background
    ================================================================ -->
    <section class="bg-cream py-24 pat:py-16 mob:py-10">
      <div class="max-w-[1200px] mx-auto px-8 mob:px-4">
        <div class="grid grid-cols-2 gap-20 items-center pat:grid-cols-1 pat:gap-8">

          <!-- Text -->
          <div class="max-w-[520px] pat:max-w-none">
            <p class="text-[12px] font-semibold tracking-[0.1em] uppercase text-tea-green mb-3">About Us</p>
            <h2 class="text-[clamp(32px,4vw,48px)] font-bold tracking-tight leading-[1.1] text-ink mb-6">
              A family business, four generations and counting.
            </h2>
            <p class="text-[16px] leading-[1.7] text-ink-2 mb-4 text-justify mob:text-left">
              We are family-owned and operated, four generations and counting. Family provides unrelenting support and our independence lets us forge our path and write our own rules. Founded by Late Khetsi Das Agarwalla in 1954 against all odds, the Goenka Family Group have since grown to become one of India's premier tea producers.
            </p>
            <p class="text-[16px] leading-[1.7] text-ink-2 mb-6 text-justify mob:text-left">
              With a presence in both CTC and Orthodox tea and by producing 20 million kilos of tea spread across 16 factories and gardens, we are one of the largest non-corporate tea producing families in India.
            </p>
            <a href="/about" class="inline-flex items-center gap-2 bg-ink text-white text-[14px] font-medium px-7 py-[14px] rounded-lg hover:bg-tea-dark transition-colors duration-150 no-underline">
              Read More
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <!-- Image -->
          <div class="aspect-square rounded-lg overflow-hidden pat:aspect-[16/10]">
            <img
              src="/images/tea-pot.jpg"
              alt="Tea pot"
              class="w-full h-full object-cover"
              width="600"
              height="600"
              loading="lazy"
              decoding="async"
            />
          </div>

        </div>
      </div>
    </section>


    <!-- ================================================================
         BRANDS GRID — cream background
    ================================================================ -->
    <section class="bg-cream pt-16 pb-24 pat:pt-12 pat:pb-16 mob:pt-8 mob:pb-12">
      <div class="max-w-[1200px] mx-auto px-8 mob:px-4">

        <!-- Header -->
        <div class="text-center mb-16 pat:mb-10">
          <p class="text-[12px] font-semibold tracking-[0.1em] uppercase text-tea-green mb-3">Our Brands</p>
          <h2 class="text-[clamp(32px,4vw,48px)] font-bold tracking-tight leading-[1.1] text-ink mb-4">
            Eight names, one standard of quality.
          </h2>
          <p class="text-[18px] leading-[1.7] text-ink-2 max-w-[640px] mx-auto">
            Each brand serves a different segment of the wholesale market — from everyday CTC granules to garden-fresh premium leaf.
          </p>
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-4 gap-5 pat:grid-cols-2 pat:gap-3.5">
          {BRANDS.map(b => (
            <a
              href={`/brands/${b.id}`}
              class="group bg-white border border-[#F0F0EE] rounded-xl px-5 py-8 flex flex-col items-center gap-3.5 no-underline transition-all duration-200 shadow-[0_1px_2px_rgba(14,14,14,0.03)] hover:shadow-[0_8px_24px_rgba(14,14,14,0.08)] hover:-translate-y-0.5"
            >
              <div class="h-[150px] flex items-center justify-center w-full pat:h-20">
                <img
                  src={b.logo}
                  alt={b.name}
                  class="max-h-[150px] max-w-full w-auto object-contain scale-[1.18] pat:max-h-[80px]"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="text-[16px] font-semibold text-ink group-hover:text-tea-green transition-colors duration-150">{b.name}</div>
              <div class="text-[12px] text-ink-3 uppercase tracking-wide font-medium">{b.maker}</div>
            </a>
          ))}
        </div>

        <!-- CTA -->
        <div class="text-center mt-12">
          <a href="/brands" class="inline-flex items-center gap-2 bg-ink text-white text-[14px] font-medium px-7 py-[14px] rounded-lg hover:bg-tea-dark transition-colors duration-150 no-underline">
            View All Brands
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

      </div>
    </section>


    <!-- ================================================================
         HOW TO BUY + CTA — combined
    ================================================================ -->
    <section class="py-20 pat:py-14 mob:py-10" style="background-color: #ffffff; background-image: radial-gradient(circle at 1px 1px, rgba(14,14,14,0.04) 1px, transparent 0); background-size: 22px 22px;">
      <div class="max-w-[1200px] mx-auto px-8 mob:px-4">

        <div class="mb-14 pat:mb-10">
          <p class="text-[12px] font-semibold tracking-[0.1em] uppercase text-tea-green mb-3">Wholesale &amp; Broker Enquiries</p>
          <h2 class="text-[clamp(32px,4vw,48px)] font-bold tracking-tight leading-[1.1] text-ink">
            Three steps from enquiry to order.
          </h2>
        </div>

        <div class="grid grid-cols-3 gap-0 divide-x divide-[#F0F0EE] pat:grid-cols-1 pat:divide-x-0 pat:divide-y pat:gap-0">
          {[
            {
              num: '01',
              title: 'Share your requirements',
              body: 'Tell us which brands, quantities, and packaging format you need. Use the contact form or write to us directly.',
            },
            {
              num: '02',
              title: 'Receive pricing and samples',
              body: 'We respond within two working days with current availability, pricing, and sample dispatch confirmation.',
            },
            {
              num: '03',
              title: 'Confirm and order',
              body: 'Once satisfied with the sample and terms, confirm your order. We handle packaging and dispatch from our Assam facilities.',
            },
          ].map(step => (
            <div class="px-10 first:pl-0 last:pr-0 pat:px-0 pat:py-8 pat:first:pt-0 pat:last:pb-0">
              <div class="text-[48px] font-bold text-tea-green leading-none tracking-tight pat:text-[36px]">{step.num}</div>
              <h3 class="text-[18px] font-semibold text-ink mt-4 mb-2">{step.title}</h3>
              <p class="text-[15px] leading-[1.7] text-ink-3 m-0">{step.body}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 pt-8 border-t border-[#F0F0EE] flex items-center justify-between gap-8 pat:flex-col pat:items-start pat:gap-4 mob:gap-5">
          <p class="text-[15px] leading-[1.7] text-ink-2 max-w-[560px] pat:max-w-none m-0">
            Send us your requirements — brands, quantity, packaging — and we will respond within two working days with availability and pricing.
          </p>
          <a href="/contact" class="inline-flex items-center gap-2 bg-tea-green text-white text-[14px] font-medium px-7 py-[14px] rounded-lg hover:bg-[#005530] transition-colors duration-150 no-underline shrink-0">
            Request Samples &amp; Pricing
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>
