---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const brands = ['Lalkilla','Krisnachura','Ratanpur','Ratanpur Premiere','Golai-bari','Abhoyapur','Dehing-patkai','Boro-golai'];
const buyerTypes = ['Trader','Retailer','Packeter','Broker','Any other'];
---

<Layout title="Contact Us — Pureassamtea" description="Get in touch with Pureassamtea for wholesale pricing, samples, and bulk tea enquiries from Upper Assam.">
  <Header />

  <main>

    <!-- HERO -->
    <section class="bg-white pt-20 pb-12 pat:pt-12 pat:pb-8 text-center">
      <div class="max-w-[760px] mx-auto px-8 mob:px-4">
        <h1 class="text-[clamp(40px,5vw,64px)] font-bold tracking-tight leading-[1.1] text-ink mb-4">Contact Us</h1>
        <p class="text-[18px] leading-[1.7] text-ink-2 pat:text-[16px]">
          Wholesale enquiries, broker partnerships, and sample requests — we read every message and reply within two working days.
        </p>
      </div>
    </section>


    <!-- SPLIT CARD -->
    <section class="bg-cream pt-8 pb-20 pat:pb-12">
      <div class="max-w-[1200px] mx-auto px-8 mob:px-4">

        <div class="grid grid-cols-2 bg-white rounded-2xl border border-[#F0F0EE] shadow-sm overflow-hidden pat:grid-cols-1">

          <!-- Left: Image -->
          <div class="relative min-h-[600px] bg-tea-dark pat:min-h-[280px]">
            <img
              src="/images/tea-pot.jpg"
              alt=""
              class="absolute inset-0 w-full h-full object-cover"
              aria-hidden="true"
              decoding="async"
              loading="lazy"
            />
          </div>

          <!-- Right: Form -->
          <div class="p-12 flex flex-col gap-[18px] pat:p-5">
            <h2 class="text-[clamp(32px,4vw,48px)] font-bold tracking-tight leading-[1.1] text-ink mb-2">Drop Us a Line</h2>

            <form id="contact-form" action="https://formspree.io/f/xykodqrb" method="POST" class="flex flex-col gap-[18px]">
              <input type="hidden" name="_subject" value="New wholesale enquiry — PureAssamTea" />

              <!-- Name -->
              <div class="flex flex-col gap-1.5">
                <label class="text-[13px] font-medium text-ink" for="name">Name *</label>
                <input id="name" type="text" name="name" placeholder="Enter your name" required
                  class="text-[15px] px-[14px] py-[13px] border border-line rounded-lg bg-white text-ink placeholder-ink-3 outline-none focus:border-tea-green focus:ring-2 focus:ring-tea-green/10 transition-all duration-150" />
              </div>

              <!-- Phone -->
              <div class="flex flex-col gap-1.5">
                <label class="text-[13px] font-medium text-ink" for="phone">Phone *</label>
                <input id="phone" type="tel" name="phone" placeholder="Enter your phone number" required
                  class="text-[15px] px-[14px] py-[13px] border border-line rounded-lg bg-white text-ink placeholder-ink-3 outline-none focus:border-tea-green focus:ring-2 focus:ring-tea-green/10 transition-all duration-150" />
              </div>

              <!-- Email -->
              <div class="flex flex-col gap-1.5">
                <label class="text-[13px] font-medium text-ink" for="email">Email *</label>
                <input id="email" type="email" name="email" placeholder="Enter your email" required
                  class="text-[15px] px-[14px] py-[13px] border border-line rounded-lg bg-white text-ink placeholder-ink-3 outline-none focus:border-tea-green focus:ring-2 focus:ring-tea-green/10 transition-all duration-150" />
              </div>

              <!-- Organization -->
              <div class="flex flex-col gap-1.5">
                <label class="text-[13px] font-medium text-ink" for="organization">Name of the Organization *</label>
                <input id="organization" type="text" name="organization" placeholder="Enter organization name" required
                  class="text-[15px] px-[14px] py-[13px] border border-line rounded-lg bg-white text-ink placeholder-ink-3 outline-none focus:border-tea-green focus:ring-2 focus:ring-tea-green/10 transition-all duration-150" />
              </div>

              <!-- City + State -->
              <div class="grid grid-cols-2 gap-4 pat:grid-cols-1">
                <div class="flex flex-col gap-1.5">
                  <label class="text-[13px] font-medium text-ink" for="city">City *</label>
                  <input id="city" type="text" name="city" placeholder="City" required
                    class="text-[15px] px-[14px] py-[13px] border border-line rounded-lg bg-white text-ink placeholder-ink-3 outline-none focus:border-tea-green focus:ring-2 focus:ring-tea-green/10 transition-all duration-150" />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-[13px] font-medium text-ink" for="state">State *</label>
                  <input id="state" type="text" name="state" placeholder="State" required
                    class="text-[15px] px-[14px] py-[13px] border border-line rounded-lg bg-white text-ink placeholder-ink-3 outline-none focus:border-tea-green focus:ring-2 focus:ring-tea-green/10 transition-all duration-150" />
                </div>
              </div>

              <!-- Brands -->
              <fieldset class="border border-line rounded-lg p-4 flex flex-col gap-2 bg-white">
                <legend class="text-[13px] font-medium text-ink px-1.5">Select the brands you are interested in *</legend>
                <div class="flex flex-col gap-1.5">
                  {brands.map(b => (
                    <label class="flex items-center gap-2.5 text-[14px] text-ink-2 cursor-pointer">
                      <input type="checkbox" name="brands" value={b}
                        class="w-4 h-4 rounded border-line accent-tea-green cursor-pointer" />
                      {b}
                    </label>
                  ))}
                </div>
              </fieldset>

              <!-- Buyer type -->
              <fieldset class="border border-line rounded-lg p-4 flex flex-col gap-2 bg-white">
                <legend class="text-[13px] font-medium text-ink px-1.5">You are a *</legend>
                <div class="flex flex-col gap-1.5">
                  {buyerTypes.map(t => (
                    <label class="flex items-center gap-2.5 text-[14px] text-ink-2 cursor-pointer">
                      <input type="radio" name="buyerType" value={t} required
                        class="w-4 h-4 border-line accent-tea-green cursor-pointer" />
                      {t}
                    </label>
                  ))}
                </div>
              </fieldset>

              <!-- Submit -->
              <button id="submit-btn" type="submit"
                class="w-full bg-tea-green text-white text-[15px] font-medium py-4 rounded-lg hover:bg-[#005530] transition-colors duration-150 mt-2">
                Submit
              </button>

              <!-- Success message (hidden until submit) -->
              <div id="form-success" class="hidden items-center gap-3 bg-[#F0F9F4] border border-[#C5E4D3] rounded-lg px-4 py-3.5">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-tea-green shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                <div>
                  <p class="text-[14px] font-semibold text-ink m-0">Enquiry sent.</p>
                  <p class="text-[13px] text-ink-3 m-0">We'll get back to you within two working days.</p>
                </div>
              </div>

            </form>
          </div>

        </div>


        <!-- Contact info cards -->
        <div class="grid grid-cols-2 gap-6 mt-12 pat:grid-cols-1">

          <!-- Email -->
          <div class="bg-white border border-[#F0F0EE] rounded-xl p-6 flex gap-4 items-start">
            <div class="w-10 h-10 bg-tea-light rounded-lg flex items-center justify-center text-tea-green shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <h6 class="text-[11px] font-semibold tracking-[0.08em] uppercase text-ink-3 mb-1">Email</h6>
              <p class="text-[15px] text-ink m-0">
                <a href="mailto:contact@pureassamtea.com" class="text-ink hover:text-tea-green no-underline transition-colors">contact@pureassamtea.com</a>
              </p>
            </div>
          </div>

          <!-- Phone -->
          <div class="bg-white border border-[#F0F0EE] rounded-xl p-6 flex gap-4 items-start">
            <div class="w-10 h-10 bg-tea-light rounded-lg flex items-center justify-center text-tea-green shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.18 6.18l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03Z"/>
              </svg>
            </div>
            <div>
              <h6 class="text-[11px] font-semibold tracking-[0.08em] uppercase text-ink-3 mb-1">Phone</h6>
              <p class="text-[15px] text-ink m-0">
                <a href="tel:03732300413" class="text-ink hover:text-tea-green no-underline transition-colors">(0373) 2300413 / 2300196</a>
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const btn     = document.getElementById('submit-btn') as HTMLButtonElement;
  const success = document.getElementById('form-success') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Sending…';
    btn.disabled = true;

    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { Accept: 'application/json' },
    });

    if (res.ok) {
      form.reset();
      btn.classList.add('hidden');
      success.classList.remove('hidden');
      success.classList.add('flex');
    } else {
      btn.textContent = 'Submit';
      btn.disabled = false;
    }
  });
</script>
