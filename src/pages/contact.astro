---
// contact.astro - Contact page with form
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const brands = [
  'Lalkilla',
  'Krisnachura', 
  'Ratanpur',
  'Ratanpur Premiere',
  'Golai-bari',
  'Abhoyapur',
  'Dehing-patkai',
  'Boro-golai'
];

const businessTypes = ['Trader', 'Retailer', 'Packeter', 'Broker', 'Any other'];
---

<Layout title="Contact Us - PureAssamTea Group">
  <Header />
  <main>
    <!-- MOBILE LAYOUT (hidden on desktop) -->
    <div class="lg:hidden">
      <!-- Mobile Titles Section -->
      <section class="bg-gradient-to-b from-[#1B4D3E] to-[#0d3328] py-10 px-5 text-center">
        <h1 class="text-2xl font-light text-white leading-tight mb-6">
          Interested in doing<br/>business with us?
        </h1>
        <h2 class="text-3xl font-normal text-white">Drop Us a Line</h2>
      </section>
      
      <!-- Mobile Form Section -->
      <section class="bg-[#FAFAF9] py-10 px-5">
        <div class="max-w-[350px] mx-auto">
          <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-6">
            <!-- Name -->
            <div>
              <label class="block text-base font-medium text-gray-700 mb-2">Name *</label>
              <input 
                type="text" 
                name="name"
                placeholder="Enter your name" 
                required
                class="w-full px-4 py-4 rounded-lg shadow-md border border-gray-200 bg-white text-gray-900 placeholder-gray-400 text-base"
              />
            </div>
            
            <!-- Phone -->
            <div>
              <label class="block text-base font-medium text-gray-700 mb-2">Phone *</label>
              <input 
                type="tel" 
                name="phone"
                placeholder="Enter your phone number" 
                required
                class="w-full px-4 py-4 rounded-lg shadow-md border border-gray-200 bg-white text-gray-900 placeholder-gray-400 text-base"
              />
            </div>
            
            <!-- Email -->
            <div>
              <label class="block text-base font-medium text-gray-700 mb-2">Email *</label>
              <input 
                type="email" 
                name="email"
                placeholder="Enter your email" 
                required
                class="w-full px-4 py-4 rounded-lg shadow-md border border-gray-200 bg-white text-gray-900 placeholder-gray-400 text-base"
              />
            </div>
            
            <!-- Organization -->
            <div>
              <label class="block text-base font-medium text-gray-700 mb-2">Name of the Organization *</label>
              <input 
                type="text" 
                name="organization"
                placeholder="Enter organization name" 
                required
                class="w-full px-4 py-4 rounded-lg shadow-md border border-gray-200 bg-white text-gray-900 placeholder-gray-400 text-base"
              />
            </div>
            
            <!-- City & State -->
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-base font-medium text-gray-700 mb-2">City *</label>
                <input 
                  type="text" 
                  name="city"
                  placeholder="City" 
                  required
                  class="w-full px-4 py-4 rounded-lg shadow-md border border-gray-200 bg-white text-gray-900 placeholder-gray-400 text-base"
                />
              </div>
              <div>
                <label class="block text-base font-medium text-gray-700 mb-2">State *</label>
                <input 
                  type="text" 
                  name="state"
                  placeholder="State" 
                  required
                  class="w-full px-4 py-4 rounded-lg shadow-md border border-gray-200 bg-white text-gray-900 placeholder-gray-400 text-base"
                />
              </div>
            </div>
            
            <!-- Brands Selection - 44px touch targets -->
            <div class="bg-white p-5 rounded-lg shadow-md border border-gray-200">
              <p class="text-base font-medium mb-4">Select the brands you are interested in *</p>
              <div class="space-y-3">
                {brands.map((brand) => (
                  <label class="flex items-center gap-3 text-base cursor-pointer min-h-[44px]">
                    <input 
                      type="checkbox" 
                      name="brands" 
                      value={brand}
                      class="w-6 h-6 rounded border-2 border-gray-300"
                    />
                    <span>{brand}</span>
                  </label>
                ))}
              </div>
            </div>
            
            <!-- Business Type - 44px touch targets -->
            <div class="bg-white p-5 rounded-lg shadow-md border border-gray-200">
              <p class="text-base font-medium mb-4">You are a *</p>
              <div class="space-y-3">
                {businessTypes.map((type) => (
                  <label class="flex items-center gap-3 text-base cursor-pointer min-h-[44px]">
                    <input 
                      type="radio" 
                      name="business_type" 
                      value={type}
                      required
                      class="w-6 h-6 border-2 border-gray-300"
                    />
                    <span>{type}</span>
                  </label>
                ))}
              </div>
            </div>
            
            <!-- Submit Button -->
            <button 
              type="submit" 
              class="w-full bg-tea-green text-white py-5 rounded-lg font-semibold text-lg hover:bg-tea-dark transition-colors min-h-[56px]"
            >
              Submit
            </button>
          </form>
          
          <p class="text-xs text-gray-500 mt-4">
            Note: Replace YOUR_FORM_ID in the form action with your Formspree form ID.
            Sign up at <a href="https://formspree.io" class="text-tea-green underline">formspree.io</a> to get your form ID.
          </p>
        </div>
      </section>
    </div>
    
    <!-- DESKTOP LAYOUT (hidden on mobile) -->
    <div class="hidden lg:block">
      <!-- Top Titles Row -->
      <section class="grid grid-cols-2 h-[120px]">
        <!-- Left Title -->
        <div class="relative flex items-center justify-center bg-gradient-to-b from-black/40 to-black/70">
          <img 
            src="/images/tea_pot.jpg" 
            alt="" 
            class="absolute inset-0 w-full h-full object-cover -z-10"
          />
          <h2 class="text-4xl font-light text-white text-center leading-tight">
            Interested in doing<br/>business with us?
          </h2>
        </div>
        
        <!-- Right Title -->
        <div class="bg-[#FAFAF9] flex items-center justify-center">
          <h2 class="text-5xl font-normal text-gray-900">Drop Us a Line</h2>
        </div>
      </section>
      
      <!-- Main Content - Split Layout -->
      <section class="grid grid-cols-2 min-h-[900px]">
        <!-- Left Side - Image -->
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-b from-black/40 to-black/70 z-10"></div>
          <img 
            src="/images/tea_pot.jpg" 
            alt="Tea Pot" 
            class="absolute inset-0 w-full h-full object-cover"
          />
        </div>
        
        <!-- Right Side - Form -->
        <div class="bg-[#FAFAF9] p-12">
          <div class="max-w-lg mx-auto">
          
          <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-4">
            <!-- Name -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
              <input 
                type="text" 
                name="name"
                placeholder="Enter your name" 
                required
                class="w-full px-4 py-3 rounded shadow-md border-0 bg-white text-gray-900 placeholder-gray-400 text-sm"
              />
            </div>
            
            <!-- Phone -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Phone *</label>
              <input 
                type="tel" 
                name="phone"
                placeholder="Enter your phone number" 
                required
                class="w-full px-4 py-3 rounded shadow-md border-0 bg-white text-gray-900 placeholder-gray-400 text-sm"
              />
            </div>
            
            <!-- Email -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
              <input 
                type="email" 
                name="email"
                placeholder="Enter your email" 
                required
                class="w-full px-4 py-3 rounded shadow-md border-0 bg-white text-gray-900 placeholder-gray-400 text-sm"
              />
            </div>
            
            <!-- Organization -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Name of the Organization *</label>
              <input 
                type="text" 
                name="organization"
                placeholder="Enter organization name" 
                required
                class="w-full px-4 py-3 rounded shadow-md border-0 bg-white text-gray-900 placeholder-gray-400 text-sm"
              />
            </div>
            
            <!-- City & State -->
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">City *</label>
                <input 
                  type="text" 
                  name="city"
                  placeholder="City" 
                  required
                  class="w-full px-4 py-3 rounded shadow-md border-0 bg-white text-gray-900 placeholder-gray-400 text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">State *</label>
                <input 
                  type="text" 
                  name="state"
                  placeholder="State" 
                  required
                  class="w-full px-4 py-3 rounded shadow-md border-0 bg-white text-gray-900 placeholder-gray-400 text-sm"
                />
              </div>
            </div>
            
            <!-- Brands Selection -->
            <div class="bg-white p-5 rounded shadow-sm">
              <p class="text-sm font-medium mb-3">Select the brands you are interested in *</p>
              <div class="space-y-2">
                {brands.map((brand) => (
                  <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input 
                      type="checkbox" 
                      name="brands" 
                      value={brand}
                      class="w-4 h-4 rounded border-gray-300"
                    />
                    <span>{brand}</span>
                  </label>
                ))}
              </div>
            </div>
            
            <!-- Business Type -->
            <div class="bg-white p-5 rounded shadow-sm">
              <p class="text-sm font-medium mb-3">You are a *</p>
              <div class="space-y-2">
                {businessTypes.map((type) => (
                  <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input 
                      type="radio" 
                      name="business_type" 
                      value={type}
                      required
                      class="w-4 h-4 border-gray-300"
                    />
                    <span>{type}</span>
                  </label>
                ))}
              </div>
            </div>
            
            <!-- Submit Button -->
            <button 
              type="submit" 
              class="w-full bg-tea-green text-white py-4 rounded font-semibold text-lg hover:bg-tea-dark transition-colors"
            >
              Submit
            </button>
          </form>
          
          <p class="text-xs text-gray-500 mt-4">
            Note: Replace YOUR_FORM_ID in the form action with your Formspree form ID.
            Sign up at <a href="https://formspree.io" class="text-tea-green underline">formspree.io</a> to get your form ID.
          </p>
        </div>
      </div>
    </section>
    </div>
  </main>
  <Footer />
</Layout>
