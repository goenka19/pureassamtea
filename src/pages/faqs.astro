---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const FAQ_GROUPS = [
  {
    id: 'ordering',
    title: 'Ordering & Enquiries',
    items: [
      {
        q: 'How do I place a wholesale order?',
        a: 'Wholesale enquiries begin on the Contact Us page. Share your organization details, the brands you are interested in, and the quantity you have in mind. Our team will respond within two working days with availability, pricing, and the next steps. Minimum order quantities vary by brand and packaging format.',
      },
      {
        q: 'Do you supply samples before a full order?',
        a: 'Yes. We send sealed reference samples for serious wholesale enquiries — traders, retailers, packeters, and brokers. Mention sample interest in your enquiry along with the brands you wish to evaluate. Sample dispatch is typically completed within five working days from confirmation.',
      },
      {
        q: 'Can I order multiple brands in a single shipment?',
        a: 'Yes. Buyers regularly combine two or three of our house brands in one consignment to balance their range. Mixed orders are consolidated at our Tinsukia facility before dispatch and travel under a single shipping document.',
      },
    ],
  },
  {
    id: 'packaging',
    title: 'Packaging',
    items: [
      {
        q: 'What packaging formats are available?',
        a: 'Our standard wholesale format is 25 kg food-grade PP bags, lined for moisture protection. Select brands are also available in 1 kg, 5 kg, and 10 kg formats for retailers and packeters. Custom packaging — including private-label printing — can be arranged on bulk orders. Speak to us about specifications.',
      },
      {
        q: 'How is the tea protected during transit?',
        a: 'Each PP bag is sealed against moisture and light, then loaded into corrugated outer cartons or palletised for export consignments. Granule integrity, aroma, and color are preserved when stored in a cool, dry place away from strong odours.',
      },
      {
        q: 'What is the shelf life of your tea?',
        a: 'Unopened CTC tea retains its character for 18 months from the date of packaging when stored as recommended. Each bag carries a batch code and packaging date for full traceability back to the garden and factory.',
      },
    ],
  },
  {
    id: 'delivery',
    title: 'Delivery & Logistics',
    items: [
      {
        q: 'Where do you ship to?',
        a: 'We dispatch across India and to wholesale partners in over twenty countries. Domestic orders move by road from Tinsukia, Assam. International orders are handled by sea freight ex-Kolkata or Haldia, with documentation prepared by our export desk.',
      },
      {
        q: 'What are typical delivery timelines?',
        a: 'Domestic dispatch begins within three to five working days of order confirmation. Transit time depends on destination — typically four to seven days within India. International sea freight ranges from three to six weeks depending on port and incoterms agreed.',
      },
      {
        q: 'Do you handle export documentation?',
        a: 'Yes. Our export team prepares the commercial invoice, packing list, certificate of origin, phytosanitary certificate, and Tea Board permit. Buyers receive a complete document set before vessel sailing for hassle-free clearance at destination.',
      },
    ],
  },
  {
    id: 'quality',
    title: 'Quality & Product',
    items: [
      {
        q: 'Where is your tea grown and processed?',
        a: 'Across sixteen factories and gardens in Assam, all owned and operated by the Goenka Family Group. Every leaf is plucked, withered, and processed in-house using the CTC (Cut, Tear, Curl) method — the same approach the family has refined since 1954.',
      },
      {
        q: 'Are your gardens certified?',
        a: 'Our gardens hold the certifications expected of a serious Indian tea producer — Tea Board of India registration, FSSAI for food safety, and additional standards for our export-bound batches. Specific certificates can be shared with buyers on request.',
      },
    ],
  },
];
---

<Layout title="FAQs — Pureassamtea" description="Frequently asked questions about ordering, packaging, shipping, and tea specifications from Pureassamtea.">
  <Header />

  <main>

    <!-- HERO -->
    <section class="bg-white pt-20 pb-12 pat:pt-12 pat:pb-8 text-center">
      <div class="max-w-[760px] mx-auto px-8">
        <p class="text-[12px] font-semibold tracking-[0.1em] uppercase text-tea-green mb-3">Frequently Asked Questions</p>
        <h1 class="text-[clamp(40px,5vw,64px)] font-bold tracking-tight leading-[1.1] text-ink mb-4">
          Answers for buyers, brokers, and partners
        </h1>
        <p class="text-[18px] leading-[1.7] text-ink-2 pat:text-[16px]">
          A short reference covering ordering, packaging, delivery, and quality. If your question is not here, write to us — we read every message and reply within two working days.
        </p>
      </div>
    </section>


    <!-- FAQ LAYOUT -->
    <section class="bg-cream pt-8 pb-20 pat:pt-6 pat:pb-14">
      <div class="max-w-[1200px] mx-auto px-8">
        <div class="grid grid-cols-[260px_1fr] gap-16 items-start pat:grid-cols-1 pat:gap-8">

          <!-- Sidebar TOC -->
          <aside class="sticky top-[104px] bg-white border border-[#F0F0EE] rounded-xl p-6 shadow-[0_1px_2px_rgba(14,14,14,0.03)] pat:static pat:top-auto">
            <h6 class="text-[11px] font-semibold tracking-[0.1em] uppercase text-ink-3 mb-3.5">On this page</h6>
            <ul class="list-none m-0 p-0 flex flex-col gap-2.5 mb-5">
              {FAQ_GROUPS.map(g => (
                <li>
                  <a href={`#faq-${g.id}`} class="text-[14px] font-medium text-ink hover:text-tea-green no-underline transition-colors leading-snug block">{g.title}</a>
                </li>
              ))}
            </ul>
            <div class="h-px bg-[#F0F0EE] mb-4"></div>
            <p class="text-[13px] text-ink-3 mb-3 leading-relaxed">Still have a question?</p>
            <a href="/contact" class="inline-flex items-center gap-2 bg-tea-green text-white text-[14px] font-medium px-[22px] py-3 rounded-lg hover:bg-[#005530] transition-colors duration-150 no-underline">
              Contact our team
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </aside>

          <!-- FAQ content -->
          <div class="flex flex-col gap-12 pat:gap-8">
            {FAQ_GROUPS.map(group => (
              <section id={`faq-${group.id}`} class="scroll-mt-[104px]">
                <h2 class="text-[24px] font-semibold tracking-tight text-ink mb-5">{group.title}</h2>
                <div class="bg-white border border-[#F0F0EE] rounded-xl overflow-hidden shadow-[0_1px_2px_rgba(14,14,14,0.03)]">
                  {group.items.map((item, ii) => (
                    <div class="faq-item border-b border-[#F0F0EE] last:border-b-0">
                      <button
                        class="faq-btn w-full bg-transparent border-0 px-6 py-[22px] flex items-center justify-between gap-6 text-left font-medium text-[16px] text-ink cursor-pointer hover:bg-[#F9F8F3] transition-colors duration-150 pat:px-[18px] pat:py-[18px] pat:text-[15px] pat:gap-4"
                        aria-expanded="false"
                      >
                        <span>{item.q}</span>
                        <span class="faq-icon w-8 h-8 rounded-full bg-[#F9F8F3] text-tea-green flex items-center justify-center shrink-0 transition-all duration-200">
                          <!-- plus -->
                          <svg class="icon-plus" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                          <!-- minus (hidden) -->
                          <svg class="icon-minus hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                        </span>
                      </button>
                      <div class="faq-answer grid grid-rows-[0fr] transition-[grid-template-rows] duration-240 ease-[cubic-bezier(0.4,0,0.2,1)]">
                        <div class="overflow-hidden">
                          <p class="text-[15px] leading-[1.7] text-ink-2 px-6 pb-[22px] pt-[18px] border-t border-[#F0F0EE] m-0 pat:px-[18px]">{item.a}</p>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </section>
            ))}
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
    const btn    = item.querySelector<HTMLButtonElement>('.faq-btn')!;
    const answer = item.querySelector<HTMLElement>('.faq-answer')!;
    const plus   = item.querySelector<SVGElement>('.icon-plus')!;
    const minus  = item.querySelector<SVGElement>('.icon-minus')!;
    const icon   = item.querySelector<HTMLElement>('.faq-icon')!;

    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';

      if (open) {
        answer.style.gridTemplateRows = '0fr';
        btn.setAttribute('aria-expanded', 'false');
        plus.classList.remove('hidden');
        minus.classList.add('hidden');
        icon.classList.remove('bg-tea-green', 'text-white');
        icon.classList.add('bg-[#F9F8F3]', 'text-tea-green');
      } else {
        answer.style.gridTemplateRows = '1fr';
        btn.setAttribute('aria-expanded', 'true');
        plus.classList.add('hidden');
        minus.classList.remove('hidden');
        icon.classList.add('bg-tea-green', 'text-white');
        icon.classList.remove('bg-[#F9F8F3]', 'text-tea-green');
      }
    });
  });
</script>
