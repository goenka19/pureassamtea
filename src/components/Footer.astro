---
// Footer.astro - Green footer as per screenshot
---

<footer class="bg-tea-green text-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Company Info -->
      <div>
        <h3 class="font-bold text-lg tracking-wider mb-2">PUREASSAMTEA</h3>
        <p class="text-white/80 text-sm mb-4">Discover A Passion</p>
        <div class="flex gap-3">
          <a href="#" class="w-8 h-8 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 transition-colors text-sm font-bold">
            f
          </a>
        </div>
      </div>
      
      <!-- Contact Info -->
      <div>
        <h4 class="font-semibold mb-4">Reach Us</h4>
        <div class="space-y-2 text-sm text-white/80">
          <p>📞 (0373) 2300413 / 2300196</p>
          <p>✉️ contact@pureassamtea.com</p>
        </div>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h4 class="font-semibold mb-4">Helpful Links</h4>
        <div class="space-y-2 text-sm">
          <a href="#" class="block text-white/80 hover:text-white transition-colors">Employee Login</a>
          <a href="#" class="block text-white/80 hover:text-white transition-colors">Job Applications</a>
          <a href="#" class="block text-white/80 hover:text-white transition-colors">Policies</a>
        </div>
      </div>
      
      <!-- Newsletter -->
      <div>
        <h4 class="font-semibold mb-4">Subscribe To Stay Updated</h4>
        <form class="space-y-2">
          <input 
            type="email" 
            placeholder="Email*" 
            class="w-full px-4 py-3 rounded bg-white text-gray-900 text-sm"
          />
          <button 
            type="submit" 
            class="w-full bg-black text-white px-4 py-3 rounded text-sm font-medium hover:bg-gray-900 transition-colors"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>
    
    <div class="border-t border-white/20 mt-12 pt-8 text-center text-sm text-white/60">
      <p>© 2021 Pureassamtea Group</p>
    </div>
  </div>
</footer>
