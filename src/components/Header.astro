---
// Header.astro - Exact match to screenshot with green Contact Us button
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
---

<header class:list={[
  "w-full z-50",
  transparent ? "absolute top-0" : "bg-white"
]}>
  {/* Desktop Header - Exact match to screenshot */}
  <div class="hidden lg:flex items-center justify-between px-12 xl:px-20 py-4 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <div class="w-10 h-12 flex items-center justify-center">
        <img 
          src="/images/logo.png" 
          alt="PureAssamTea Logo" 
          class="w-full h-full object-contain"
        />
      </div>
      <span class="text-tea-green font-bold text-sm tracking-[2px] uppercase">PUREASSAMTEA GROUP</span>
    </a>

    <!-- Desktop Navigation - Contact Us as green text per screenshot -->
    <nav class="flex items-center gap-10">
      <a href="/about" class="text-sm text-gray-900 hover:text-tea-green transition-colors">About Us</a>
      <a href="/brands" class="text-sm text-gray-900 hover:text-tea-green transition-colors">Our Brands</a>
      <a href="/portfolio" class="text-sm text-gray-900 hover:text-tea-green transition-colors">Our Portfolio</a>
      <a href="/contact" class="text-sm text-tea-green font-semibold">Contact Us</a>
    </nav>
  </div>

  {/* Mobile Header - Get Quote button design */}
  <div class="lg:hidden flex items-center justify-between px-5 py-4 border-b border-gray-100">
    <!-- Logo (shorter text for mobile) -->
    <a href="/" class="flex items-center gap-2">
      <div class="w-9 h-11 flex items-center justify-center bg-gradient-to-br from-orange-500 to-red-600 rounded">
        <span class="text-white font-bold text-lg">G</span>
      </div>
      <span class="text-tea-green font-bold text-xs tracking-wide">PUREASSAMTEA</span>
    </a>

    <!-- Right Side: Get Quote + Hamburger -->
    <div class="flex items-center gap-3">
      <a 
        href="/contact" 
        class="bg-tea-green text-white px-5 py-2.5 rounded-md text-sm font-semibold"
      >
        Get Quote
      </a>
      
      <button 
        id="menu-toggle"
        class="p-2 text-gray-800"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile Navigation Menu -->
  <nav 
    id="mobile-menu" 
    class="hidden lg:hidden bg-white border-t border-gray-100 absolute w-full left-0"
  >
    <div class="flex flex-col">
      <a href="/about" class="px-6 py-4 text-gray-800 border-b border-gray-50 font-medium">About Us</a>
      <a href="/brands" class="px-6 py-4 text-gray-800 border-b border-gray-50 font-medium">Our Brands</a>
      <a href="/portfolio" class="px-6 py-4 text-gray-800 border-b border-gray-50 font-medium">Our Portfolio</a>
      <a href="/contact" class="px-6 py-4 text-tea-green font-medium">Contact Us</a>
    </div>
  </nav>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
