---
const navLinks = [
  { label: 'About Us',   href: '/about' },
  { label: 'Our Brands', href: '/brands' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 h-[80px] bg-white border-b border-[#F0F0EE] transition-all duration-200">
  <div class="max-w-[1200px] mx-auto h-full px-8 flex items-center justify-between gap-8">

    <!-- Wordmark -->
    <a href="/" class="flex items-center gap-1 shrink-0 no-underline">
      <img
        src="/images/goenka-logo.png"
        alt="Pureassamtea"
        height="34"
        width="34"
        class="h-[34px] w-auto"
        decoding="sync"
        fetchpriority="high"
      />
      <span class="-ml-3 text-tea-green font-bold text-sm tracking-[2px] uppercase leading-none">PUREASSAMTEA</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden pat:hidden md:flex items-center gap-9">
      {navLinks.map(l => (
        <a href={l.href} class="text-[14px] font-medium text-ink hover:text-tea-green transition-colors duration-150 no-underline">{l.label}</a>
      ))}
      <a href="/contact" class="inline-flex items-center gap-2 bg-tea-green text-white text-[14px] font-medium px-[22px] py-[10px] rounded-lg hover:bg-[#005530] transition-colors duration-150 no-underline">
        Contact Us
      </a>
    </nav>

    <!-- Mobile: Contact Us + hamburger -->
    <div class="flex items-center gap-3 md:hidden">
      <a href="/contact" class="bg-tea-green text-white text-[13px] font-semibold px-3 py-2 rounded-lg no-underline whitespace-nowrap">
        Contact Us
      </a>
      <button
        id="hamburger"
        class="p-2 text-ink"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile dropdown -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden absolute top-[80px] left-0 right-0 bg-white border-b border-[#F0F0EE] shadow-md"
  >
    <div class="flex">
      <a href="/about"  class="flex-1 py-4 text-[15px] font-medium text-ink text-center border-r border-[#F0F0EE] no-underline hover:text-tea-green">About Us</a>
      <a href="/brands" class="flex-1 py-4 text-[15px] font-medium text-ink text-center no-underline hover:text-tea-green">Our Brands</a>
    </div>
  </nav>
</header>

<!-- Spacer so content starts below fixed header -->
<div class="h-[80px]"></div>

<script>
  const header = document.getElementById('site-header');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  // Scroll: add blur backdrop
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('bg-white/90', 'backdrop-blur-md');
      header?.classList.remove('bg-white');
    } else {
      header?.classList.remove('bg-white/90', 'backdrop-blur-md');
      header?.classList.add('bg-white');
    }
  }, { passive: true });

  // Hamburger toggle
  hamburger?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    hamburger.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
